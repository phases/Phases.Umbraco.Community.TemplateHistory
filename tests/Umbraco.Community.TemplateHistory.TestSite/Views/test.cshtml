@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Test>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
    Layout = null;
    var pageTitle = Model?.Name ?? "Test";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Template History Test Site</title>
    <link rel="stylesheet" href="/css/test .css" />
</head>
<body class="test-page">
    <header class="test-header">
        <h1>@pageTitle</h1>
        <p>Template History test content — test template v1</p>
    </header>

    <main class="test-main">
        <p>Edit and save this template in Settings → Templates to create history entries.</p>
        <p>Document type: Test</p>
    </main>
    <script src="/scripts/test.js"></script>
</body>
</html>
